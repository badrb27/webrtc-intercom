{
  "name": "family-intercom-desktop",
  "version": "1.0.0",
  "description": "Family Intercom - Desktop Tray App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "node-fetch": "^3.3.2",
    "otpauth": "^9.5.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.family.intercom",
    "productName": "Family Intercom",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
